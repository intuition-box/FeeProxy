{
  "name": "intuition-fee-proxy-template",
  "version": "2.0.0-alpha",
  "private": true,
  "description": "Intuition Fee Proxy Template — monorepo (SDK + safe-tx + webapp) for the multi-tenant FeeProxy singleton",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "sdk:build": "bun --filter @intuition-fee-proxy/sdk build",
    "sdk:test": "bun --filter @intuition-fee-proxy/sdk test",
    "webapp:dev": "bun --filter @intuition-fee-proxy/webapp dev",
    "webapp:build": "bun --filter @intuition-fee-proxy/webapp build",
    "webapp:preview": "bun --filter @intuition-fee-proxy/webapp preview",
    "safe:tx": "bun packages/safe-tx/bin/safe-propose.ts",
    "safe:tx:test": "bun --filter @intuition-fee-proxy/safe-tx test",
    "safe:tx:typecheck": "bun --filter @intuition-fee-proxy/safe-tx typecheck"
  },
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.3.0",
    "@types/node": "^20.0.0",
    "@intuition-fee-proxy/sdk": "workspace:*",
    "viem": "^2.21.0"
  },
  "dependencies": {
    "@ledgerhq/hw-app-eth": "^7.8.0",
    "@ledgerhq/hw-transport-node-hid": "^6.33.1",
    "@trezor/connect": "^9.7.3"
  }
}
