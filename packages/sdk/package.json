{
  "name": "@intuition-fee-proxy/sdk",
  "version": "2.0.0-alpha.0",
  "description": "ABI, addresses, chain config, fee math and type-safe readers for the Intuition multi-tenant FeeProxy singleton.",
  "license": "MIT",
  "author": "Intuition",
  "homepage": "https://intuition.box",
  "repository": {
    "type": "git",
    "url": "https://github.com/intuition-box/intuition-fee-proxy-template.git",
    "directory": "packages/sdk"
  },
  "keywords": [
    "intuition",
    "fee-proxy",
    "erc-7936",
    "multivault",
    "viem",
    "ethereum"
  ],
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "bun test",
    "prepublishOnly": "bun run build"
  },
  "peerDependencies": {
    "viem": "^2.0.0"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "viem": "^2.0.0"
  },
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  }
}
