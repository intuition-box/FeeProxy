# Copy to .env.local and fill in values before running `bun webapp:dev`.

# WalletConnect Cloud project ID — required if you want WalletConnect connectors
# to work (MetaMask and other injected wallets work without it).
# Free: https://cloud.walletconnect.com/
VITE_WALLETCONNECT_PROJECT_ID=

# Public URL of the hosted "useless dApp" test demo (demo-dapp/). When set, the
# docs "Test dApp" section shows an "Open the test dApp" button so affiliates
# can route a real fee through their id without building their own dApp first.
VITE_DEMO_URL=

# Dev override for the testnet. If set, the webapp points at this Factory
# address instead of the V2_ADDRESSES table in the SDK. Useful to wire a
# fresh deploy (local hardhat node or testnet) without touching
# @intuition-fee-proxy/sdk. Standard and sponsored implementation addresses
# are not overridable — they're read live from the Factory on-chain.
VITE_FACTORY_ADDRESS=
